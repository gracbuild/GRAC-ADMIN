@model IReadOnlyList<ControlManagement.Web.Models.ControlMenuItem>
@using ControlManagement.Web.Models
@{
    var currentArea = Convert.ToString(ViewData["CurrentArea"]) ?? "";
}

@foreach (var item in Model)
{
    var hasChildren = item.Children.Count > 0;
    var isCurrent = IsCurrent(item, currentArea);
    var isOpen = isCurrent || item.Children.Any(child => IsCurrentOrParent(child, currentArea));
    <li class="nav-item @(isCurrent ? "active" : "") @(isOpen && hasChildren ? "menu-open" : "")" data-menu-key="@item.MenuKey">
        <a href="@MenuUrl(item)" class="nav-link @(isCurrent ? "active" : isOpen ? "active-parent" : "")">
            <i class="nav-icon @IconClass(item, hasChildren)"></i>
            <p>
                @item.MenuName
                @if (hasChildren)
                {
                    <i class="right fas fa-angle-left"></i>
                }
            </p>
        </a>
        @if (hasChildren)
        {
            <ul class="nav nav-treeview">
                @await Html.PartialAsync("_ControlMenuTree", item.Children, new ViewDataDictionary(ViewData) { ["CurrentArea"] = currentArea })
            </ul>
        }
    </li>
}

@functions {
    private static bool IsCurrentOrParent(ControlMenuItem item, string currentArea) =>
        IsCurrent(item, currentArea)
        || item.Children.Any(child => IsCurrentOrParent(child, currentArea));

    private static bool IsCurrent(ControlMenuItem item, string currentArea)
    {
        if (item.MenuKey.Equals(currentArea, StringComparison.OrdinalIgnoreCase)) return true;
        var areaKey = ExtractAreaKey(item.MenuUrl);
        return !string.IsNullOrWhiteSpace(areaKey)
            && areaKey.Equals(currentArea, StringComparison.OrdinalIgnoreCase);
    }

    private static string? ExtractAreaKey(string? menuUrl)
    {
        if (string.IsNullOrWhiteSpace(menuUrl)) return null;
        const string marker = "areaKey=";
        var index = menuUrl.IndexOf(marker, StringComparison.OrdinalIgnoreCase);
        if (index < 0) return null;
        var value = menuUrl[(index + marker.Length)..];
        var ampIndex = value.IndexOf('&');
        if (ampIndex >= 0) value = value[..ampIndex];
        return Uri.UnescapeDataString(value).Trim();
    }

    private string MenuUrl(ControlMenuItem item)
    {
        if (item.Children.Count > 0) return "#";
        if (!string.IsNullOrWhiteSpace(item.MenuUrl)) return NormalizeMenuUrl(item.MenuUrl, item);
        if (item.Screen is null) return "#";
        return Url.Action("Index", "Repository", new { areaKey = item.Screen.Key }) ?? "#";
    }

    private string NormalizeMenuUrl(string menuUrl, ControlMenuItem item)
    {
        var value = menuUrl.Trim();
        if (string.IsNullOrWhiteSpace(value) || value == "#") return "#";
        if (Uri.TryCreate(value, UriKind.Absolute, out _)) return value;
        if (value.Equals("dashboard", StringComparison.OrdinalIgnoreCase)) return Url.Action("Index", "Repository") ?? "#";
        if (value.StartsWith("~/", StringComparison.Ordinal)) return Url.Content(value);

        var pathBase = Context.Request.PathBase.Value?.Trim('/') ?? "";
        value = value.Replace('\\', '/').TrimStart('/');
        if (!string.IsNullOrWhiteSpace(pathBase)
            && value.StartsWith(pathBase + "/", StringComparison.OrdinalIgnoreCase))
            value = value[(pathBase.Length + 1)..];

        if (!value.Contains('/', StringComparison.Ordinal)
            && RepositoryScreen.All.Any(screen => screen.Key.Equals(value, StringComparison.OrdinalIgnoreCase)))
            return Url.Action("Index", "Repository", new { areaKey = value }) ?? "#";

        if (!value.Contains('/', StringComparison.Ordinal)
            && RepositoryScreen.All.Any(screen => screen.Key.Equals(item.MenuKey, StringComparison.OrdinalIgnoreCase)))
            return Url.Action("Index", "Repository", new { areaKey = item.MenuKey }) ?? "#";

        return Url.Content("~/" + value);
    }

    private static string IconClass(ControlMenuItem item, bool hasChildren)
    {
        if (!string.IsNullOrWhiteSpace(item.IconClass))
        {
            var icon = item.IconClass.Trim();
            if (icon.StartsWith("fa ", StringComparison.OrdinalIgnoreCase)
                || icon.StartsWith("fas ", StringComparison.OrdinalIgnoreCase)
                || icon.StartsWith("far ", StringComparison.OrdinalIgnoreCase)
                || icon.StartsWith("fab ", StringComparison.OrdinalIgnoreCase))
                return icon;
            return $"fas fa-{icon}";
        }
        if (!string.IsNullOrWhiteSpace(item.Screen?.Icon)) return $"fas fa-{item.Screen.Icon}";
        return hasChildren ? "fas fa-folder" : "far fa-circle";
    }
}
