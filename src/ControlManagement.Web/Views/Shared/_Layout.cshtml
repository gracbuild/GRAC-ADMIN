@using ControlManagement.Web.Models
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var screens = ViewBag.Screens as RepositoryScreen[] ?? RepositoryScreen.All;
    var menuItems = ViewBag.MenuItems as IReadOnlyList<ControlMenuItem> ?? [];
    var currentArea = (ViewBag.CurrentArea as string) ?? Context.Request.Query["areaKey"].ToString();
    if (string.IsNullOrWhiteSpace(currentArea)) currentArea = ViewContext.RouteData.Values["areaKey"]?.ToString() ?? "";
    var isDashboard = string.IsNullOrWhiteSpace(currentArea) && ViewContext.RouteData.Values["action"]?.ToString() != "AuditTrace";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | GRAC</title>
    <meta name="csrf-token" content="@Antiforgery.GetAndStoreTokens(Context).RequestToken" />
    <link rel="icon" type="image/x-icon" href="~/css/Images/favicon.ico" />
    <link rel="stylesheet" href="~/css/cacca-styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/phosphor/regular/style.css" />
    <link rel="stylesheet" href="~/css/phosphor/bold/style.css" />
    <link rel="stylesheet" href="~/css/phosphor/light/style.css" />
    <link rel="stylesheet" href="~/css/phosphor/thin/style.css" />
    <link rel="stylesheet" href="~/css/phosphor/fill/style.css" />
    <link rel="stylesheet" href="~/css/phosphor/duotone/style.css" />
    <link rel="stylesheet" href="~/lib/FrontEnd/plugins/fontawesome-free/css/all.min.css" />
    <link rel="stylesheet" href="~/lib/fontawesome/css/all.min.css" />
    <link rel="stylesheet" href="~/lib/FrontEnd/plugins/icheck-bootstrap/icheck-bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/FrontEnd/dist/css/adminlte.min.css" />
    <link rel="stylesheet" href="~/css/sweet-alert.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/grac-dialog.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/control-management.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/topbar-auth.css" asp-append-version="true" />
    <script>
        (function () {
            try {
                var saved = localStorage.getItem('cacca_sidebar_collapsed');
                if (saved !== null && JSON.parse(saved)) {
                    document.addEventListener('DOMContentLoaded', function () {
                        document.body.classList.add('sidebar-collapse');
                    });
                }
            } catch (e) { }
        })();
    </script>
</head>
<body class="hold-transition sidebar-mini layout-fixed sidebar-open layout-footer-fixed">
    <nav class="main-header navbar navbar-expand navbar-white navbar-light">
        <ul class="navbar-nav">
            <li class="nav-item">
                <a class="nav-link" data-widget="pushmenu" href="#" role="button" aria-label="Toggle navigation">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M7.49984 18.3334H12.4998C16.6665 18.3334 18.3332 16.6667 18.3332 12.5V7.50002C18.3332 3.33335 16.6665 1.66669 12.4998 1.66669H7.49984C3.33317 1.66669 1.6665 3.33335 1.6665 7.50002V12.5C1.6665 16.6667 3.33317 18.3334 7.49984 18.3334Z" stroke="#292D32" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M7.5 1.66669V18.3334" stroke="#292D32" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </a>
            </li>
            <li class="nav-item d-none d-sm-flex align-items-center">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a asp-controller="Repository" asp-action="Index">Home</a></li>
                    <li class="breadcrumb-item">Repository Management</li>
                    @if (!isDashboard)
                    {
                        <li class="breadcrumb-item active" aria-current="page">@ViewData["Title"]</li>
                    }
                </ol>
            </li>
        </ul>
        <ul class="navbar-nav ml-auto">
            <li class="nav-item dropdown">
                <a class="nav-link" data-toggle="dropdown" href="#" aria-label="User menu">
                    <div class="user-panel d-flex">
                        <div class="image">
                            <img src="~/lib/FrontEnd/dist/img/avatar5.png" class="img-circle elevation-2" alt="User Image" />
                        </div>
                        <div class="info"><span id="spnUserName">@(ViewBag.UserName ?? "Control User")</span></div>
                    </div>
                </a>
                <div class="dropdown-menu dropdown-menu-lg dropdown-menu-right cacca-ddw">
                    <form class="logout-form" asp-controller="Login" asp-action="Logout" method="post">
                        <button class="dropdown-item" type="submit"><i class="fa fa-power-off"></i> Sign Out</button>
                    </form>
                </div>
            </li>
            <li class="nav-item">
                <a class="nav-link" data-widget="fullscreen" href="#" role="button" aria-label="Fullscreen"><i class="fas fa-expand-arrows-alt"></i></a>
            </li>
        </ul>
    </nav>

    <aside class="main-sidebar sidebar-dark-primary elevation-4">
        <a asp-controller="Repository" asp-action="Index" class="brand-link">
            <img src="~/css/Images/Logo.png" class="brand-image logo-expanded" alt="GRAC" />
            <img src="~/css/Images/logo-cacca.png" class="brand-image logo-collapsed" alt="GRAC" />
        </a>
        <div class="sidebar">
            <nav class="mt-2">
                <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu" data-accordion="false">
                    <li class="nav-item">
                        <a asp-controller="Repository" asp-action="Index" class="nav-link @(isDashboard ? "active" : "")">
                            <i class="nav-icon fas fa-chart-line"></i><p>Dashboard</p>
                        </a>
                    </li>
                    @if (menuItems.Count > 0)
                    {
                        @await Html.PartialAsync("_ControlMenuTree", menuItems, new ViewDataDictionary(ViewData) { ["CurrentArea"] = currentArea })
                    }
                </ul>
            </nav>
        </div>
    </aside>

    <div class="content-wrapper">
        <div id="Loader" class="div-loader" style="display:none;"><div class="loader"></div></div>
        <main role="main" class="content">
            <input id="HostName" name="HostName" value="@ViewBag.HostName" type="hidden" />
            <div class="container-fluid">@RenderBody()</div>
        </main>
    </div>

    <script src="~/lib/FrontEnd/plugins/jquery/jquery.min.js"></script>
    <script src="~/lib/FrontEnd/plugins/jquery-ui/jquery-ui.min.js"></script>
    <script>$.widget.bridge('uibutton', $.ui.button)</script>
    <script src="~/lib/FrontEnd/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/FrontEnd/plugins/jquery-knob/jquery.knob.min.js"></script>
    <script src="~/lib/FrontEnd/dist/js/adminlte.js"></script>
    <script src="~/lib/FrontEnd/plugins/jquery-validation/jquery.validate.min.js"></script>
    <script src="~/lib/FrontEnd/plugins/datatables/jquery.dataTables.min.js"></script>
    <script src="~/lib/FrontEnd/plugins/datatables-bs4/js/dataTables.bootstrap4.min.js"></script>
    <script src="~/lib/FrontEnd/plugins/datatables-buttons/js/dataTables.buttons.min.js"></script>
    <script src="~/js/grac-dialog.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        window.cmPathBase = "@Context.Request.PathBase";
        window.cmCurrentArea = "@currentArea";
        window.HostName = $("#HostName").val();
        function syncControlMenuState() {
            try {
                var nav = document.querySelector('.nav-sidebar');
                if (!nav) return;

                var currentArea = (window.cmCurrentArea || new URLSearchParams(window.location.search).get('areaKey') || '').toLowerCase();
                var activeLinks = [];

                nav.querySelectorAll('.nav-link.active, .nav-link.active-parent, .nav-link.active-current').forEach(function (link) {
                    activeLinks.push(link);
                });

                if (!activeLinks.length && currentArea) {
                    nav.querySelectorAll('[data-menu-key]').forEach(function (item) {
                        if ((item.getAttribute('data-menu-key') || '').toLowerCase() === currentArea) {
                            var link = item.querySelector(':scope > .nav-link');
                            if (link) {
                                link.classList.add('active', 'active-current');
                                item.classList.add('active');
                                activeLinks.push(link);
                            }
                        }
                    });
                }

                if (!activeLinks.length) {
                    var currentUrl = new URL(window.location.href);
                    var currentPath = currentUrl.pathname.replace(/\/+$/, '').toLowerCase();
                    var currentSearch = currentUrl.search.toLowerCase();
                    nav.querySelectorAll('a.nav-link[href]').forEach(function (link) {
                        var href = link.getAttribute('href') || '';
                        if (!href || href === '#') return;
                        var linkUrl = new URL(href, window.location.origin);
                        var linkPath = linkUrl.pathname.replace(/\/+$/, '').toLowerCase();
                        var linkSearch = linkUrl.search.toLowerCase();
                        if (linkPath === currentPath && (!linkSearch || linkSearch === currentSearch)) {
                            link.classList.add('active', 'active-current');
                            var li = link.closest('.nav-item');
                            if (li) li.classList.add('active');
                            activeLinks.push(link);
                        }
                    });
                }

                activeLinks.forEach(function (link) {
                    var item = link.closest('.nav-item');
                    while (item) {
                        var manuallyCollapsed = item.dataset.userCollapsed === 'true';
                        item.classList.toggle('menu-open', !manuallyCollapsed);
                        var parentLink = item.querySelector(':scope > .nav-link');
                        if (parentLink && parentLink !== link && parentLink.getAttribute('href') === '#') {
                            parentLink.classList.add('active-parent');
                        }
                        var tree = item.querySelector(':scope > .nav-treeview');
                        if (tree) {
                            tree.style.display = manuallyCollapsed ? 'none' : 'block';
                            if (manuallyCollapsed) tree.setAttribute('hidden', 'hidden');
                            else tree.removeAttribute('hidden');
                        }
                        item = item.parentElement && item.parentElement.closest('.nav-item');
                    }
                });
            } catch (error) {
                console.error('ControlManagement menu state sync failed', error);
            }
        }
        function bindControlMenuClickPersistence() {
            var nav = document.querySelector('.nav-sidebar');
            if (!nav || nav.dataset.activeStateBound === 'true') return;
            nav.dataset.activeStateBound = 'true';
            nav.addEventListener('click', function (event) {
                var link = event.target.closest && event.target.closest('a.nav-link');
                if (!link || !nav.contains(link)) return;
                var href = (link.getAttribute('href') || '').trim();
                var item = link.closest('.nav-item');
                var childTree = item && item.querySelector(':scope > .nav-treeview');

                if (href === '#' && childTree) {
                    event.preventDefault();
                    event.stopPropagation();
                    event.stopImmediatePropagation();
                    var shouldOpen = !item.classList.contains('menu-open');
                    item.dataset.userCollapsed = shouldOpen ? 'false' : 'true';
                    item.classList.toggle('menu-open', shouldOpen);
                    link.classList.toggle('active-parent', shouldOpen);
                    childTree.style.display = shouldOpen ? 'block' : 'none';
                    if (shouldOpen) childTree.removeAttribute('hidden');
                    else childTree.setAttribute('hidden', 'hidden');
                    return false;
                }

                if (href && href !== '#') {
                    nav.querySelectorAll('.nav-link.active-current').forEach(function (active) {
                        active.classList.remove('active-current');
                        if (!active.classList.contains('active-parent')) active.classList.remove('active');
                    });
                    link.classList.add('active', 'active-current');
                    if (item) item.classList.add('active');
                    var parent = item;
                    while (parent) {
                        parent.dataset.userCollapsed = 'false';
                        parent.classList.add('menu-open');
                        var parentLink = parent.querySelector(':scope > .nav-link');
                        if (parentLink && parentLink !== link && parentLink.getAttribute('href') === '#') {
                            parentLink.classList.add('active-parent');
                        }
                        var tree = parent.querySelector(':scope > .nav-treeview');
                        if (tree) {
                            tree.style.display = 'block';
                            tree.removeAttribute('hidden');
                        }
                        parent = parent.parentElement && parent.parentElement.closest('.nav-item');
                    }
                }
            }, true);
        }
        function enforceControlMenuState() {
            bindControlMenuClickPersistence();
            syncControlMenuState();
            window.setTimeout(syncControlMenuState, 50);
            window.setTimeout(syncControlMenuState, 250);
            window.setTimeout(syncControlMenuState, 750);
        }
        document.addEventListener('DOMContentLoaded', enforceControlMenuState);
        window.addEventListener('load', enforceControlMenuState);
        $(document).on('shown.lte.treeview collapsed.lte.treeview expanded.lte.treeview', syncControlMenuState);
        $(document).on('collapsed.lte.pushmenu shown.lte.pushmenu', function () {
            try { localStorage.setItem('cacca_sidebar_collapsed', document.body.classList.contains('sidebar-collapse')); } catch (e) { }
            syncControlMenuState();
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
