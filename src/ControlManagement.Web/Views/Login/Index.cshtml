@model ControlManagement.Web.Models.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>GRAC | Log in</title>
    <link rel="icon" type="image/x-icon" href="~/css/images/favicon.ico" />
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
</head>
<body class="login-split">
    <div class="login-wrapper">
        <div class="split-card">
            <div class="brand-panel">
                <div class="brand-inner">
                    <div class="brand-logo">
                        <img src="~/css/images/logo.png" alt="GRAC Logo" />
                    </div>
                </div>
            </div>
            <div class="form-panel">
                <div class="form-card">
                    <div class="greeting">
                        <h1>Welcome to GRAC</h1>
                    </div>
                    <form asp-action="Index" method="post">
                        <input asp-for="ReturnUrl" type="hidden" />
                        <div asp-validation-summary="ModelOnly" class="validation-message"></div>
                        <div class="form-group">
                            <label asp-for="Email" class="form-label">Login ID or Email</label>
                            <input asp-for="Email" class="form-control" type="text" placeholder="Enter Login ID or Email" autocomplete="username" autofocus />
                            <span asp-validation-for="Email" class="validation-message"></span>
                        </div>
                        <div class="form-group">
                            <div class="password-heading">
                                <label asp-for="Password" class="form-label"></label>
                                <a class="forgot-link" asp-action="ForgotPassword">Forgot Password?</a>
                            </div>
                            <input asp-for="Password" class="form-control" placeholder="Enter Password" autocomplete="current-password" />
                            <span asp-validation-for="Password" class="validation-message"></span>
                        </div>
                        <button type="submit" class="btn-signin">Sign In</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <script src="~/js/login.js" asp-append-version="true"></script>
</body>
</html>
