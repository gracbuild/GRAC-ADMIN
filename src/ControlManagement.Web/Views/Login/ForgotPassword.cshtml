@model ControlManagement.Web.Models.ForgotPasswordViewModel
@{
    Layout = null;
    ViewData["Title"] = "Forgot Password";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>GRAC | Forgot Password</title>
    <link rel="icon" type="image/x-icon" href="~/css/images/favicon.ico" />
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
</head>
<body class="login-split">
    <div class="login-wrapper">
        <div class="split-card">
            <div class="brand-panel">
                <div class="brand-inner">
                    <div class="brand-logo">
                        <img src="~/css/images/logo.png" alt="GRAC Logo" />
                    </div>
                </div>
            </div>
            <div class="form-panel">
                <div class="form-card">
                    @if (!Model.Submitted)
                    {
                        <div class="greeting">
                            <h1>Forgot Password</h1>
                            <p class="form-help">Enter your Login ID or Email and we will notify your administrator to reset your password. You will sign in with the default password once it is reset.</p>
                        </div>
                        <form asp-action="ForgotPassword" method="post">
                            <div asp-validation-summary="ModelOnly" class="validation-message"></div>
                            <div class="form-group">
                                <label asp-for="Identifier" class="form-label">Login ID or Email</label>
                                <input asp-for="Identifier" class="form-control" type="text" placeholder="Enter Login ID or Email" autocomplete="username" autofocus />
                                <span asp-validation-for="Identifier" class="validation-message"></span>
                            </div>
                            <button type="submit" class="btn-signin">Request Reset</button>
                        </form>
                        <p class="form-help" style="margin-top:16px;">
                            <a class="forgot-link" asp-action="Index">&larr; Back to Login</a>
                        </p>
                    }
                    else
                    {
                        <div class="greeting">
                            <h1>Request Received</h1>
                            <p class="form-help">If an active account exists for that Login ID or Email, your administrator has been notified to reset the password. Once the password is reset, sign in using the default password and you will be asked to set a new one.</p>
                        </div>
                        <p class="form-help" style="margin-top:16px;">
                            <a class="forgot-link" asp-action="Index">&larr; Back to Login</a>
                        </p>
                    }
                </div>
            </div>
        </div>
    </div>
</body>
</html>
