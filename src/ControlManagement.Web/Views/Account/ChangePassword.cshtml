@model ControlManagement.Web.Models.ChangePasswordViewModel
@{
    Layout = null;
    ViewData["Title"] = "Change Password";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>GRAC | Change Password</title>
    <link rel="icon" type="image/x-icon" href="~/css/images/favicon.ico" />
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
</head>
<body class="login-split">
    <div class="login-wrapper">
        <div class="split-card">
            <div class="brand-panel">
                <div class="brand-inner">
                    <div class="brand-logo">
                        <img src="~/css/images/logo.png" alt="GRAC Logo" />
                    </div>
                </div>
            </div>
            <div class="form-panel">
                <div class="form-card">
                    <div class="greeting">
                        <h1>@(Model.IsFirstLogin ? "Set Your Password" : "Change Password")</h1>
                        @if (Model.IsFirstLogin)
                        {
                            <p class="form-help">Your administrator created this account with a default password. Please choose a new password to continue.</p>
                        }
                    </div>
                    <form asp-action="ChangePassword" method="post">
                        <input asp-for="ReturnUrl" type="hidden" />
                        <input asp-for="IsFirstLogin" type="hidden" />
                        <div asp-validation-summary="ModelOnly" class="validation-message"></div>
                        <div class="form-group">
                            <label asp-for="CurrentPassword" class="form-label">@(Model.IsFirstLogin ? "Default / Current Password" : "Current Password")</label>
                            <input asp-for="CurrentPassword" class="form-control" placeholder="Enter Current Password" autocomplete="current-password" autofocus />
                            <span asp-validation-for="CurrentPassword" class="validation-message"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="NewPassword" class="form-label">New Password</label>
                            <input asp-for="NewPassword" class="form-control" placeholder="At least 8 characters" autocomplete="new-password" />
                            <span asp-validation-for="NewPassword" class="validation-message"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="ConfirmPassword" class="form-label">Confirm New Password</label>
                            <input asp-for="ConfirmPassword" class="form-control" placeholder="Re-enter New Password" autocomplete="new-password" />
                            <span asp-validation-for="ConfirmPassword" class="validation-message"></span>
                        </div>
                        <button type="submit" class="btn-signin">Update Password</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
