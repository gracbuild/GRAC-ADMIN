@model ControlManagement.Web.Models.RepositoryScreen
@{ ViewData["Title"]=Model.Title; var permissions = ViewBag.Permissions as string[] ?? []; }
<link rel="stylesheet" href="~/css/repository-actions.css" asp-append-version="true" />
@* Obligation tree-grids share the side-panel + preview styles defined for the matrix form. *@
@if(Model.Key=="obligation-mappings" || Model.Key=="obligations"){<link rel="stylesheet" href="~/css/obligation-mapping-form.css" asp-append-version="true" />}
<div class="page-heading"><div><p class="eyebrow">Repository Management / @Model.Title</p><h1 id="pageTitle">@Model.Title</h1><p>@Model.Description</p></div><div class="page-heading-actions"><button class="button" id="backToParent" type="button" hidden><i class="fa-solid fa-arrow-left"></i> Back</button>@if(Model.Key!="audit-trace" && Model.Key!="change-management" && Model.Key!="source-control-mappings" && permissions.Contains("ADD")){<button class="button primary" id="addRecord"><i class="fa-solid fa-plus"></i> Add</button>}</div></div>
<section class="panel">
 <div class="toolbar"><input id="search" placeholder="Search repository..." /><select id="authority" hidden><option value="">All authorities</option></select><select id="artifact" hidden><option value="">All artifacts</option></select><select id="release" hidden><option value="">All releases</option></select><select id="changeModule" hidden><option value="">All modules</option></select><select id="changeActionType" hidden><option value="">All action types</option></select><select id="status"><option value="">All statuses</option></select><button class="button toolbar-icon-button" id="clearFilters" type="button" aria-label="Clear filters" title="Clear filters"><i class="fa-solid fa-filter-circle-xmark" aria-hidden="true"></i></button><button class="button toolbar-icon-button" id="refresh" type="button" aria-label="Refresh list" title="Refresh list"><i class="fa-solid fa-rotate-right" aria-hidden="true"></i></button></div>
  <div class="table-wrap @(Model.Key=="source-structure" || Model.Key=="framework-statements" || Model.Key=="obligations" || Model.Key=="obligation-mappings" || Model.Key=="audit-trace" ? "tree-grid-wrap" : "")"><table><thead><tr>@foreach(var column in Model.Columns){<th>@(column switch { "EntityType" => "Module / Entity", "ModuleLabel" => "Module", "RecordReference" => "Record Name / Reference", "ActionType" => "Action Type", "FieldName" => "Field Changed", "FromValue" => "Old Value", "ToValue" => "New Value", "ChangedBy" => "Changed By", "ChangedOn" => "Changed On", "ObligationName" => "Obligation Name", "ExecutionFrequency" => "Execution Frequency", "AssuranceFrequency" => "Assurance Frequency", "RetentionRequirement" => "Retention Period", "RetentionPeriod" => "Retention Period", "EvidenceCount" => "Evidence", "MappingCount" => "Mappings", _ => column })</th>}<th>Actions</th></tr></thead><tbody id="repositoryRows"><tr><td colspan="@(Model.Columns.Length+1)" class="empty">Loading...</td></tr></tbody></table></div>
  @if(Model.Key=="audit-trace"){<div class="audit-pager" id="auditPager" hidden><span id="auditPagerInfo">Showing 0 records</span><div><label>Rows <select id="auditPageSize"><option>10</option><option selected>25</option><option>50</option><option>100</option></select></label><button class="button toolbar-icon-button" id="auditPrev" type="button" title="Previous page"><i class="fa-solid fa-chevron-left"></i></button><span id="auditPageInfo">Page 1 of 1</span><button class="button toolbar-icon-button" id="auditNext" type="button" title="Next page"><i class="fa-solid fa-chevron-right"></i></button></div></div>}
  @if(Model.Key=="user-management" || Model.Key=="role-management" || Model.Key=="menu-management" || Model.Key=="role-permissions"){<div class="grid-pager" id="gridPager" hidden><span id="gridPagerInfo">Showing 0 records</span><div><label>Rows <select id="gridPageSize"><option>10</option><option selected>25</option><option>50</option><option>100</option></select></label><button class="button toolbar-icon-button" id="gridFirst" type="button" title="First page" aria-label="First page"><i class="fa-solid fa-angles-left" aria-hidden="true"></i></button><button class="button toolbar-icon-button" id="gridPrev" type="button" title="Previous page" aria-label="Previous page"><i class="fa-solid fa-chevron-left" aria-hidden="true"></i></button><span id="gridPageInfo">Page 1 of 1</span><button class="button toolbar-icon-button" id="gridNext" type="button" title="Next page" aria-label="Next page"><i class="fa-solid fa-chevron-right" aria-hidden="true"></i></button><button class="button toolbar-icon-button" id="gridLast" type="button" title="Last page" aria-label="Last page"><i class="fa-solid fa-angles-right" aria-hidden="true"></i></button></div></div>}
</section>
<dialog id="recordDialog"><form id="recordForm"><div class="dialog-heading"><div><h2 id="dialogTitle">@Model.Title</h2><p id="dialogDescription">Maintain repository details.</p></div><button type="button" class="icon-button" id="closeRecord" aria-label="Close">x</button></div><div id="formMessage" class="form-message" hidden></div><div class="form-grid" id="recordFields"></div><div class="dialog-actions"><button type="button" class="button" id="cancelRecord">Cancel / Back</button><button type="button" class="button primary" id="saveRecord">Save</button></div></form></dialog>
@section Scripts { <script>window.cmScreen=@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));window.cmApi="@ViewBag.ApiBaseUrl";window.cmPermissions=@Html.Raw(System.Text.Json.JsonSerializer.Serialize(permissions));</script><script src="~/js/repository.js" asp-append-version="true"></script> }
