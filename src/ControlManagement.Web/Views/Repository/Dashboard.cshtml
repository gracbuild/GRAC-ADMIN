@using ControlManagement.Web.Models
@{ ViewData["Title"]="Overview"; var screens=ViewBag.Screens as RepositoryScreen[] ?? RepositoryScreen.All; }
<div class="page-heading"><div><p class="eyebrow">Repository Workspace</p><h1>Repository Management</h1><p>Regulatory intelligence, change management, and traceability in one standalone module.</p></div><a class="button primary" asp-controller="Repository" asp-action="Index" asp-route-areaKey="authorities">Start onboarding</a></div>
<section class="kpis"><article><span>Repository areas</span><strong>@screens.Length</strong><small>Metadata-driven management screens</small></article><article><span>Traceability</span><strong>100%</strong><small>Soft delete and immutable audit history</small></article><article><span>Framework logic</span><strong>Data</strong><small>No named framework behavior in code</small></article></section>
<section class="panel"><div class="panel-heading"><div><h2>Repository Areas</h2><p>Onboard any authority and artifact without redesigning the application.</p></div></div><div class="area-grid">@foreach(var screen in screens){<a class="area-card" asp-controller="Repository" asp-action="Index" asp-route-areaKey="@screen.Key"><i class="fa-solid fa-@screen.Icon"></i><div><strong>@screen.Title</strong><span>@screen.Description</span></div></a>}</div></section>
